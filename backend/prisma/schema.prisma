// CRM Freelancers — esquema de datos (monolito modular).
// Una sola base de datos PostgreSQL respalda todos los módulos.
// Las fronteras entre módulos se respetan en la capa de servicios,
// no a nivel de esquema. Los modelos se agrupan por módulo con comentarios.
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  runtime      = "nodejs"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ───────────────────────────── auth / users ─────────────────────────────

enum Role {
  ADMIN
  MEMBER
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  role         Role     @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Modo agencia: un MEMBER pertenece a la cuenta de un ADMIN (accountOwner).
  // El ADMIN tiene accountOwnerId nulo (su propia cuenta). El "accountId" con
  // el que se aíslan los datos es accountOwnerId ?? id.
  accountOwnerId String?
  accountOwner   User?   @relation("AccountMembers", fields: [accountOwnerId], references: [id], onDelete: Cascade)
  members        User[]  @relation("AccountMembers")

  // Datos propiedad de la cuenta (aislamiento por accountId).
  companies      Company[]
  contacts       Contact[]
  deals          Deal[]
  proposals      Proposal[]
  projects       Project[]
  activities     Activity[]
  tasks          Task[]
  invoices       Invoice[]
  tags              Tag[]
  attachments       Attachment[]
  notifications     Notification[]
  refreshTokens     RefreshToken[]
  timeEntries       TimeEntry[]
  proposalTemplates ProposalTemplate[]
  companyProfile    CompanyProfile?
  settings          Setting[]
}

// Refresh tokens persistidos (uno por sesión). Permiten rotación y revocación:
// el id es el `jti` firmado en el token; al renovar se revoca el anterior y se
// emite uno nuevo. Un reuso de token revocado invalida toda la sesión.
model RefreshToken {
  id        String    @id @default(uuid())
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId])
}

// ───────────────────────────── settings ─────────────────────────────

// Datos de empresa del usuario usados para emitir facturas.
model CompanyProfile {
  id           String   @id @default(uuid())
  businessName String
  taxId        String?
  email        String?
  phone        String?
  address      String?
  logoUrl      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String @unique
}

// Pares clave/valor de configuración por usuario.
model Setting {
  id        String   @id @default(uuid())
  key       String
  value     String
  updatedAt DateTime @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  @@unique([ownerId, key])
}

// ───────────────────────────── contacts ─────────────────────────────

model Company {
  id        String   @id @default(uuid())
  name      String
  website   String?
  industry  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  contacts Contact[]

  @@index([ownerId])
}

model Contact {
  id        String   @id @default(uuid())
  firstName String
  lastName  String?
  email     String?
  phone     String?
  position  String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  companyId String?

  deals      Deal[]
  proposals  Proposal[]
  projects   Project[]
  invoices   Invoice[]
  activities Activity[]
  tasks      Task[]

  @@index([ownerId])
  @@index([companyId])
}

// ───────────────────────────── deals (pipeline) ─────────────────────────────

enum DealStage {
  NEW
  CONTACTED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

model Deal {
  id            String    @id @default(uuid())
  title         String
  value         Decimal   @default(0) @db.Decimal(12, 2)
  stage         DealStage @default(NEW)
  expectedClose DateTime?
  lostReason    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  contactId String?

  proposals    Proposal[]
  activities   Activity[]
  tasks        Task[]
  project      Project?
  stageHistory DealStageHistory[]

  @@index([ownerId])
  @@index([stage])
}

// Historial de cambios de etapa (auditoría del avance).
model DealStageHistory {
  id        String    @id @default(uuid())
  fromStage DealStage?
  toStage   DealStage
  changedAt DateTime  @default(now())

  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId String

  @@index([dealId])
}

// ───────────────────────────── proposals ─────────────────────────────

enum ProposalStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

model Proposal {
  id        String         @id @default(uuid())
  title     String
  status    ProposalStatus @default(DRAFT)
  currency  String         @default("USD")
  total     Decimal        @default(0) @db.Decimal(12, 2)
  notes     String?
  sentAt    DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Restrict)
  contactId String

  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId String?

  items ProposalItem[]

  // Proyecto generado al aceptar la propuesta (1:1). El vínculo lo crea la
  // conversión Propuesta aceptada → Proyecto; la FK vive en Project.proposalId.
  project Project?

  @@index([ownerId])
}

model ProposalItem {
  id          String  @id @default(uuid())
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)

  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
  proposalId String

  @@index([proposalId])
}

// Plantilla reutilizable de propuesta: precarga ítems y notas al crear una.
model ProposalTemplate {
  id        String   @id @default(uuid())
  name      String
  currency  String   @default("USD")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  items ProposalTemplateItem[]

  @@index([ownerId])
}

model ProposalTemplateItem {
  id          String  @id @default(uuid())
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)

  template   ProposalTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId String

  @@index([templateId])
}

// ───────────────────────────── projects ─────────────────────────────

enum ProjectStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(ACTIVE)
  startDate   DateTime?
  endDate     DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  // Cliente dueño del proyecto. Obligatorio (fase contract aplicada).
  // Restrict: no se puede borrar un contacto que aún tenga proyectos.
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Restrict)
  contactId String

  // Un proyecto puede derivar de una propuesta aceptada (1:1) y/o de una
  // oportunidad ganada. Ambos vínculos son opcionales e independientes: el
  // cliente del proyecto es contactId, no depende de ninguno de los dos.
  proposal   Proposal? @relation(fields: [proposalId], references: [id], onDelete: SetNull)
  proposalId String?   @unique

  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: SetNull)
  dealId String? @unique

  milestones  Milestone[]
  invoices    Invoice[]
  timeEntries TimeEntry[]
  tasks       Task[]
  activities  Activity[]

  @@index([ownerId])
  @@index([contactId])
}

// Registro de tiempo dedicado a un proyecto (time-tracking).
model TimeEntry {
  id          String   @id @default(uuid())
  description String
  minutes     Int
  date        DateTime @default(now())
  createdAt   DateTime @default(now())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@index([ownerId])
  @@index([projectId])
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  DONE
}

model Milestone {
  id      String          @id @default(uuid())
  title   String
  dueDate DateTime?
  status  MilestoneStatus @default(PENDING)

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  @@index([projectId])
}

// ───────────────────────────── activities & tasks ─────────────────────────────

enum ActivityType {
  NOTE
  CALL
  EMAIL
  MEETING
}

model Activity {
  id        String       @id @default(uuid())
  type      ActivityType @default(NOTE)
  content   String
  createdAt DateTime     @default(now())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String?

  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId String?

  // Proyecto asociado (opcional): permite el historial de actividad del proyecto.
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?

  @@index([ownerId])
  @@index([projectId])
}

enum TaskStatus {
  PENDING
  DONE
}

model Task {
  id        String     @id @default(uuid())
  title     String
  dueDate   DateTime?
  status    TaskStatus @default(PENDING)
  createdAt DateTime   @default(now())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  contact   Contact? @relation(fields: [contactId], references: [id], onDelete: Cascade)
  contactId String?

  deal   Deal?   @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId String?

  // Proyecto asociado (opcional): permite las tareas propias del proyecto.
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String?

  @@index([ownerId])
  @@index([dueDate])
  @@index([projectId])
}

// ───────────────────────────── invoices ─────────────────────────────

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  OVERDUE
}

model Invoice {
  id        String        @id @default(uuid())
  number    String
  status    InvoiceStatus @default(DRAFT)
  currency  String        @default("USD")
  total     Decimal       @default(0) @db.Decimal(12, 2)
  issuedAt  DateTime?
  dueDate   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId String

  // Cliente de la factura. Denormalizado: el servicio lo fija siempre desde
  // project.contactId (nunca viene del request). Permite listar "facturas del
  // cliente" sin el salto factura → proyecto → oportunidad. Obligatorio (fase
  // contract aplicada). Restrict: no se borra un contacto con facturas.
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Restrict)
  contactId String

  payments Payment[]

  @@unique([ownerId, number])
  @@index([ownerId])
  @@index([status])
  @@index([contactId])
}

model Payment {
  id     String   @id @default(uuid())
  amount Decimal  @db.Decimal(12, 2)
  paidAt DateTime @default(now())
  method String?

  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  invoiceId String

  @@index([invoiceId])
}

// ───────────────────────────── tags ─────────────────────────────

enum TaggableType {
  CONTACT
  DEAL
  PROJECT
}

model Tag {
  id    String  @id @default(uuid())
  name  String
  color String?

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  taggables Taggable[]

  @@unique([ownerId, name])
}

// Relación polimórfica: una etiqueta aplicada a un contacto u oportunidad.
model Taggable {
  id         String       @id @default(uuid())
  entityType TaggableType
  entityId   String

  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)
  tagId String

  @@unique([tagId, entityType, entityId])
  @@index([entityType, entityId])
}

// ───────────────────────────── files ─────────────────────────────

enum AttachableType {
  CONTACT
  DEAL
  PROJECT
  PROPOSAL
  INVOICE
}

model Attachment {
  id         String         @id @default(uuid())
  filename   String
  url        String
  mimeType   String?
  size       Int?
  entityType AttachableType
  entityId   String
  createdAt  DateTime       @default(now())

  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerId String

  @@index([ownerId])
  @@index([entityType, entityId])
}

// ───────────────────────────── notifications ─────────────────────────────

enum NotificationType {
  REMINDER
  DUE_DATE
  STAGE_CHANGE
  INVOICE_OVERDUE
}

model Notification {
  id        String           @id @default(uuid())
  type      NotificationType
  message   String
  link      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId String

  @@index([userId, read])
}
